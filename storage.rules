rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email != null &&
        request.auth.token.email == "Ehsan0921@gmail.com";
    }

    // Original path style: EhsanMopersonal-website/products/...
    match /EhsanMopersonal-website/products/{product}/{version}/{fileName} {
      allow read, write, delete: if isAuthenticated();
    }

    // Simpler path style: products/... (used by admin upload)
    match /products/{allPaths=**} {
      allow read, write, delete: if isAuthenticated();
    }

    match /projects/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Homepage/site images managed from the admin theme settings.
    match /site-images/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
